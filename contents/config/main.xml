<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
      http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
    <kcfgfile name=""/>
    <group name="General">
        <entry name="isLightTheme" type="Bool">
            <label>Use Light Theme</label>
            <default>false</default>
        </entry>
        <entry name="ticker" type="String">
            <label>Single Stock Ticker</label>
            <default>AAPL</default>
        </entry>
        <entry name="isMultiMode" type="Bool">
            <label>Enable Multi-Stock List Mode</label>
            <default>false</default>
        </entry>
        <entry name="showTwoList" type="Bool">
            <label>Show Two List</label>
            <default>false</default>
        </entry>
        <entry name="multiTickers" type="String">
            <label>Comma separated list of tickers</label>
            <default>AAPL, TSLA</default>
        </entry>
        <entry name="sortAlphabetically" type="Bool">
            <label>Sort Multi-Stock List Alphabetically</label>
            <default>false</default>
        </entry>
        <entry name="swapNameAndTicker" type="Bool">
            <label>Swap company name and ticker symbol</label>
            <default>false</default>
        </entry>
        <entry name="refreshInterval" type="Int">
            <label>Refresh Interval (minutes)</label>
            <default>5</default>
        </entry>

        <entry name="chartRange" type="String">
            <label>Data History Range</label>
            <default>1D</default>
        </entry>

        <entry name="limitHours" type="Bool">
            <label>Only update during specific hours</label>
            <default>false</default>
        </entry>
        <entry name="skipWeekendRefresh" type="Bool">
            <label>Do not refresh data on weekends</label>
            <default>true</default>
        </entry>
        <entry name="startHour" type="Int">
            <default>9</default>
        </entry>
        <entry name="startMinute" type="Int">
            <default>15</default>
        </entry>
        <entry name="endHour" type="Int">
            <default>15</default>
        </entry>
        <entry name="endMinute" type="Int">
            <default>30</default>
        </entry>
        <entry name="tickerColor" type="Color">
            <label>Ticker Text Color</label>
            <default>#FFFFFF</default>
        </entry>
        <entry name="tickerOpacity" type="Int">
            <label>Ticker Text Opacity</label>
            <default>100</default>
        </entry>
        <entry name="priceColor" type="Color">
            <label>Price Text Color</label>
            <default>#FFFFFF</default>
        </entry>
        <entry name="priceOpacity" type="Int">
            <label>Price Text Opacity</label>
            <default>100</default>
        </entry>
        <entry name="positiveColor" type="Color">
            <label>Positive Change Color</label>
            <default>#4cd964</default>
        </entry>
        <entry name="negativeColor" type="Color">
            <label>Negative Change Color</label>
            <default>#FF3B30</default>
        </entry>
        <entry name="bgOpacity" type="Int">
            <label>Background Opacity Base (Percent)</label>
            <default>100</default>
        </entry>
        <entry name="hideChangePercentage" type="Bool">
            <label>Hide Stock Change Percentage (Panel View)</label>
            <default>false</default>
        </entry>
        <entry name="hideTimestamps" type="Bool">
            <label>Hide Update Timestamps</label>
            <default>true</default>
        </entry>
        <entry name="formatPrices" type="Bool">
            <label>Format stock price with commas</label>
            <default>true</default>
        </entry>
        <entry name="hideDecimals" type="Bool">
            <label>Hide decimals in stock price</label>
            <default>false</default>
        </entry>
        
        <!-- Portfolio Tracking -->
        <entry name="portfolioData" type="String">
            <label>Portfolio holdings data (JSON)</label>
            <default></default>
        </entry>AnswerThePublic.com
        <entry name="showPortfolioMode" type="Bool">
            <label>Show portfolio profit/loss in views</label>
            <default>false</default>
        </entry>
    </group>
</kcfg>
